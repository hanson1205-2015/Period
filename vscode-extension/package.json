{
  "name": "period-language",
  "displayName": "Period Language",
  "description": "Language support for Period: an elegant programming language that ends every statement with a period.",
  "version": "1.0.6",
  "publisher": "period",
  "license": "MIT",
  "icon": "period.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ExploreMaths/Period.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "period",
    "language",
    "lsp"
  ],
  "activationEvents": [
    "onLanguage:period"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "period",
        "aliases": [
          "Period",
          "period"
        ],
        "extensions": [
          ".period",
          ".periodi"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./period.svg",
          "dark": "./period.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "period",
        "scopeName": "source.period",
        "path": "./syntaxes/period.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "period-icons",
        "label": "Period Icons",
        "path": "./fileicons/period-icon-theme.json"
      }
    ],
    "commands": [
      {
        "command": "period.runFile",
        "title": "Run Period File",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "period.runFile",
          "when": "editorLangId == period",
          "group": "navigation@2"
        }
      ]
    },
    "configurationDefaults": {
      "[period]": {
        "editor.minimap.showRegionSectionHeaders": false,
        "editor.minimap.showMarkSectionHeaders": false
      }
    },
    "configuration": {
      "title": "Period Language",
      "properties": {
        "period.languageServerPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Period language server executable. Leave empty to use 'period' from PATH."
        }
      }
    }
  },
  "scripts": {
    "set-version": "node set-version.js",
    "package": "npm run set-version && vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.9.2",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  }
}
