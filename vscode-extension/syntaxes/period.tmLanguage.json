{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Period",
  "scopeName": "source.period",
  "fileTypes": [".period"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#statement-terminator" },
    { "include": "#class-declaration" },
    { "include": "#new-expression" },
    { "include": "#keyword" },
    { "include": "#method-call" },
    { "include": "#property-access" },
    { "include": "#function-call" },
    { "include": "#string" },
    { "include": "#docstring" },
    { "include": "#number" },
    { "include": "#constant" },
    { "include": "#operator" },
    { "include": "#identifier" }
  ],
  "repository": {
    "class-declaration": {
      "patterns": [
        {
          "name": "meta.class.declaration.period",
          "begin": "^[ \\t]*([Cc]lass)\\b\\s+",
          "beginCaptures": {
            "1": { "name": "storage.type.period" }
          },
          "end": "\\s*:",
          "patterns": [
            {
              "name": "entity.name.type.class.period",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            }
          ]
        }
      ]
    },
    "new-expression": {
      "patterns": [
        {
          "name": "meta.new.expression.period",
          "match": "\\b(new)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.period" },
            "2": { "name": "entity.name.type.class.period" }
          }
        }
      ]
    },
    "method-call": {
      "patterns": [
        {
          "name": "meta.method.call.period",
          "match": "\\b(to)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.period" },
            "2": { "name": "entity.name.function.method.period" }
          }
        }
      ]
    },
    "property-access": {
      "patterns": [
        {
          "name": "meta.this.property.period",
          "match": "\\b(this)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.period" },
            "2": { "name": "variable.other.property.period" }
          }
        },
        {
          "name": "meta.the.property.period",
          "match": "\\b(the)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+\\b(of)\\b",
          "captures": {
            "1": { "name": "keyword.control.period" },
            "2": { "name": "variable.other.property.period" },
            "3": { "name": "keyword.control.period" }
          }
        }
      ]
    },
    "comment": {
      "patterns": [
        {
          "name": "comment.line.double-dash.period",
          "match": "(--).*"
        }
      ]
    },
    "statement-terminator": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.period",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.colon.period",
          "match": ":"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "comment": "Capitalized keywords are only valid at the start of a line.",
          "name": "keyword.control.period",
          "match": "^[ \\t]*(Define|Class|Init|If|Then|Otherwise|While|For|In|Repeat|Return|Returns|Import|Let|Be|Set|To|With|This|New|Tell|Of|The|From|And|Or|Not)\\b"
        },
        {
          "name": "keyword.control.period",
          "match": "\\b(define|class|init|if|then|otherwise|while|for|in|repeat|return|returns|import|let|be|set|to|with|this|new|tell|of|the|from|and|or|not)\\b"
        },
        {
          "comment": "Capitalized built-ins at the start of a line.",
          "name": "support.function.builtin.period",
          "match": "^[ \\t]*(Show|Input)\\b"
        },
        {
          "comment": "Capitalized constants at the start of a line.",
          "name": "constant.language.period",
          "match": "^[ \\t]*(True|False|Nothing)\\b"
        },
        {
          "name": "support.type.builtin.period",
          "match": "\\b(any|never|nothing|boolean|integer|number|string|list|dictionary|function|class)\\b"
        },
        {
          "name": "support.function.builtin.period",
          "match": "\\b(show|input)\\b"
        },
        {
          "name": "support.function.builtin.period",
          "match": "\\b(length|string|number|type|range)\\b(?=\\s+with)"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.period",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s+with)"
        }
      ]
    },
    "docstring": {
      "patterns": [
        {
          "name": "string.quoted.double.docstring.period",
          "begin": "^\\s*\"",
          "end": "\"\\s*(?=\\.)",
          "patterns": [
            {
              "name": "constant.character.escape.period",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "string": {
      "name": "string.quoted.double.period",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.period",
          "match": "\\\\."
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.period",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "constant": {
      "patterns": [
        {
          "name": "constant.language.period",
          "match": "\\b(true|false|nothing)\\b"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.period",
          "match": "(\\+|-\\b|\\*|\\*\\*|/|%|==|!=|<=|>=|<|>|=)"
        }
      ]
    },
    "identifier": {
      "patterns": [
        {
          "name": "variable.other.period",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
