{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Period",
  "scopeName": "source.period",
  "fileTypes": [".period"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#statement-terminator" },
    { "include": "#class-declaration" },
    { "include": "#new-expression" },
    { "include": "#keyword" },
    { "include": "#function-call" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#constant" },
    { "include": "#operator" },
    { "include": "#identifier" }
  ],
  "repository": {
    "class-declaration": {
      "patterns": [
        {
          "name": "meta.class.declaration.period",
          "begin": "\\b(class)\\b\\s+",
          "beginCaptures": {
            "1": { "name": "storage.type.period" }
          },
          "end": "\\s*:",
          "patterns": [
            {
              "name": "entity.name.type.class.period",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            }
          ]
        }
      ]
    },
    "new-expression": {
      "patterns": [
        {
          "name": "meta.new.expression.period",
          "match": "\\b(new)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.period" },
            "2": { "name": "entity.name.type.class.period" }
          }
        }
      ]
    },
    "comment": {
      "patterns": [
        {
          "name": "comment.line.double-dash.period",
          "match": "(--).*"
        }
      ]
    },
    "statement-terminator": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.period",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.colon.period",
          "match": ":"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "storage.type.period",
          "match": "\\b(define|class|init)\\b"
        },
        {
          "name": "keyword.control.period",
          "match": "\\b(if|then|otherwise|while|repeat|return|returns)\\b"
        },
        {
          "name": "keyword.other.period",
          "match": "\\b(let|be|set|to|show|with|this|new|tell|of|the)\\b"
        },
        {
          "name": "keyword.operator.logical.period keyword",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "support.type.builtin.period",
          "match": "\\b(nothing|boolean|integer|number|string|list|dictionary|function|class)\\b"
        },
        {
          "name": "support.function.builtin.period",
          "match": "\\b(show|input)\\b"
        },
        {
          "name": "support.function.builtin.period",
          "match": "\\b(length|string|number|type)\\b(?=\\s+with)"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.period",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s+with)"
        }
      ]
    },
    "string": {
      "name": "string.quoted.double.period",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.period",
          "match": "\\\\."
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.period",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "constant": {
      "patterns": [
        {
          "name": "constant.language.period",
          "match": "\\b(true|false|nothing)\\b"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.period",
          "match": "(\\+|-\\b|\\*|\\*\\*|/|%|==|!=|<=|>=|<|>|=)"
        }
      ]
    },
    "identifier": {
      "patterns": [
        {
          "name": "variable.other.period",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
